{
  "name": "sticky-connections-bridge",
  "version": "1.0.1",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/main.js",
    "build": "pkg . && mv sticky-connections-bridge-macos-arm64 dist/macos/sticky-connections-bridge-macos-arm64 && mv sticky-connections-bridge-win-x64.exe dist/windows/sticky-connections-bridge-win-x64.exe"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "bin": "src/main.js",
  "pkg": {
    "targets": [
      "node18-win-x64",
      "node18-macos-arm64"
    ]
  }
}
